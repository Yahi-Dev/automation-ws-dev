# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
# uploads (archivos subidos localmente, no versionar)
public/uploads/
public/uploads/posts/

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local Windows shortcut to the .env file (machine-specific, do not version)
env.url

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# logs
*.log
logs/

# caches
.turbo/
.cache/
*.tsbuildinfo

# herramientas locales y archivos generados (no versionar)
.agents/
.skills/
skills-lock.json
